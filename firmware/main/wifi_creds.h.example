// Copy this file to wifi_creds.h and fill in your network.
// wifi_creds.h is gitignored so credentials don't get committed.
#pragma once

#define WIFI_SSID "your-wifi-ssid"
#define WIFI_PASS "your-wifi-password"

// URL of the dashboard's daily.json (GitHub Pages or your own host).
#define DAILY_JSON_URL    "https://art-mon.github.io/orrery/data/daily.json"

// URL of the daily voice briefing MP3 (mono, 24 kHz recommended).
#define BRIEFING_MP3_URL  "https://art-mon.github.io/orrery/data/briefing.mp3"

// URL of the OTA firmware manifest. See docs/firmware.md § OTA version manifest.
#define VERSION_JSON_URL  "https://art-mon.github.io/orrery/data/version.json"
